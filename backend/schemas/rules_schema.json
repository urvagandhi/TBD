{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rules_schema.json",
  "title": "Journal Formatting Rules Schema",
  "description": "Validates all rule JSON files in backend/rules/",
  "type": "object",
  "required": [
    "style_name",
    "document",
    "title_page",
    "abstract",
    "headings",
    "citations",
    "references",
    "figures",
    "tables",
    "equations",
    "general_rules"
  ],
  "additionalProperties": true,
  "properties": {
    "style_name": {
      "type": "string",
      "minLength": 1
    },
    "document": {
      "type": "object",
      "required": [
        "font",
        "font_size",
        "line_spacing",
        "alignment",
        "columns",
        "margins"
      ],
      "additionalProperties": false,
      "properties": {
        "font": {
          "type": "string",
          "minLength": 1
        },
        "font_size": {
          "type": "number",
          "minimum": 1
        },
        "line_spacing": {
          "type": "number",
          "minimum": 0.5
        },
        "alignment": {
          "type": "string",
          "enum": [
            "left",
            "justify",
            "center",
            "right"
          ]
        },
        "columns": {
          "type": "number",
          "minimum": 1,
          "maximum": 3
        },
        "margins": {
          "type": "object",
          "required": [
            "top",
            "bottom",
            "left",
            "right"
          ],
          "additionalProperties": false,
          "properties": {
            "top": {
              "type": "string"
            },
            "bottom": {
              "type": "string"
            },
            "left": {
              "type": "string"
            },
            "right": {
              "type": "string"
            }
          }
        }
      }
    },
    "title_page": {
      "type": "object",
      "required": [
        "title_case",
        "title_bold",
        "title_centered",
        "title_font_size"
      ],
      "additionalProperties": false,
      "properties": {
        "title_case": {
          "type": "string"
        },
        "title_bold": {
          "type": "boolean"
        },
        "title_centered": {
          "type": "boolean"
        },
        "title_font_size": {
          "type": "number"
        }
      }
    },
    "abstract": {
      "type": "object",
      "required": [
        "label",
        "label_bold",
        "label_centered",
        "label_italic",
        "max_words",
        "indent_first_line",
        "keywords_present",
        "keywords_label",
        "keywords_italic"
      ],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string"
        },
        "label_bold": {
          "type": "boolean"
        },
        "label_centered": {
          "type": "boolean"
        },
        "label_italic": {
          "type": "boolean"
        },
        "max_words": {
          "type": "number",
          "minimum": 1
        },
        "indent_first_line": {
          "type": "boolean"
        },
        "keywords_present": {
          "type": "boolean"
        },
        "keywords_label": {
          "type": "string"
        },
        "keywords_italic": {
          "type": "boolean"
        }
      }
    },
    "headings": {
      "type": "object",
      "required": [
        "H1",
        "H2",
        "H3"
      ],
      "additionalProperties": false,
      "properties": {
        "H1": {
          "$ref": "#/$defs/heading"
        },
        "H2": {
          "$ref": "#/$defs/heading"
        },
        "H3": {
          "$ref": "#/$defs/heading"
        },
        "H4": {
          "$ref": "#/$defs/heading"
        },
        "H5": {
          "$ref": "#/$defs/heading"
        }
      }
    },
    "citations": {
      "type": "object",
      "required": [
        "style",
        "brackets",
        "format_one_author",
        "format_two_authors",
        "format_three_plus",
        "format_numbered",
        "include_page_for_quotes",
        "page_format"
      ],
      "additionalProperties": false,
      "properties": {
        "style": {
          "type": "string",
          "enum": [
            "author-date",
            "numbered",
            "footnote"
          ]
        },
        "brackets": {
          "type": "string",
          "enum": [
            "parentheses",
            "square",
            "none"
          ]
        },
        "format_one_author": {
          "type": [
            "string",
            "null"
          ]
        },
        "format_two_authors": {
          "type": [
            "string",
            "null"
          ]
        },
        "format_three_plus": {
          "type": [
            "string",
            "null"
          ]
        },
        "narrative_one": {
          "type": [
            "string",
            "null"
          ]
        },
        "narrative_two": {
          "type": [
            "string",
            "null"
          ]
        },
        "narrative_three_plus": {
          "type": [
            "string",
            "null"
          ]
        },
        "same_author_same_year": {
          "type": [
            "string",
            "null"
          ]
        },
        "multiple_sources": {
          "type": [
            "string",
            "null"
          ]
        },
        "multiple_sort_order": {
          "type": [
            "string",
            "null"
          ]
        },
        "no_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "in_press": {
          "type": [
            "string",
            "null"
          ]
        },
        "page_number_quote": {
          "type": [
            "string",
            "null"
          ]
        },
        "page_range_quote": {
          "type": [
            "string",
            "null"
          ]
        },
        "format_numbered": {
          "type": [
            "string",
            "null"
          ]
        },
        "include_page_for_quotes": {
          "type": "boolean"
        },
        "page_format": {
          "type": "string"
        }
      }
    },
    "references": {
      "type": "object",
      "required": [
        "section_label",
        "label_bold",
        "label_centered",
        "label_italic",
        "ordering",
        "hanging_indent",
        "indent_size",
        "line_spacing",
        "space_between_entries",
        "formats"
      ],
      "additionalProperties": false,
      "properties": {
        "section_label": {
          "type": "string"
        },
        "label_bold": {
          "type": "boolean"
        },
        "label_centered": {
          "type": "boolean"
        },
        "label_italic": {
          "type": "boolean"
        },
        "ordering": {
          "type": "string",
          "enum": [
            "alphabetical",
            "appearance"
          ]
        },
        "hanging_indent": {
          "type": "boolean"
        },
        "indent_size": {
          "type": "string"
        },
        "line_spacing": {
          "type": "number"
        },
        "space_between_entries": {
          "type": "boolean"
        },
        "max_authors_before_et_al": {
          "type": "number",
          "minimum": 1
        },
        "formats": {
          "type": "object",
          "required": [
            "journal_article",
            "book",
            "book_chapter",
            "website",
            "conference_paper"
          ],
          "additionalProperties": true,
          "properties": {
            "journal_article": {
              "type": "string"
            },
            "book": {
              "type": "string"
            },
            "book_chapter": {
              "type": "string"
            },
            "book_chapter_multiple_editors": {
              "type": "string"
            },
            "website": {
              "type": "string"
            },
            "conference_paper": {
              "type": "string"
            }
          }
        }
      }
    },
    "figures": {
      "type": "object",
      "required": [
        "label_prefix",
        "label_bold",
        "label_italic",
        "caption_position",
        "caption_italic",
        "caption_alignment",
        "numbering",
        "note_label"
      ],
      "additionalProperties": false,
      "properties": {
        "label_prefix": {
          "type": "string"
        },
        "label_bold": {
          "type": "boolean"
        },
        "label_italic": {
          "type": "boolean"
        },
        "caption_position": {
          "type": "string",
          "enum": [
            "above",
            "below"
          ]
        },
        "caption_italic": {
          "type": "boolean"
        },
        "caption_alignment": {
          "type": "string",
          "enum": [
            "left",
            "center",
            "right"
          ]
        },
        "numbering": {
          "type": "string",
          "enum": [
            "arabic",
            "roman"
          ]
        },
        "note_label": {
          "type": "string"
        }
      }
    },
    "tables": {
      "type": "object",
      "required": [
        "label_prefix",
        "label_bold",
        "label_italic",
        "caption_position",
        "caption_italic",
        "caption_alignment",
        "numbering",
        "border_style",
        "note_label"
      ],
      "additionalProperties": false,
      "properties": {
        "label_prefix": {
          "type": "string"
        },
        "label_bold": {
          "type": "boolean"
        },
        "label_italic": {
          "type": "boolean"
        },
        "caption_position": {
          "type": "string",
          "enum": [
            "above",
            "below"
          ]
        },
        "caption_italic": {
          "type": "boolean"
        },
        "caption_alignment": {
          "type": "string",
          "enum": [
            "left",
            "center",
            "right"
          ]
        },
        "numbering": {
          "type": "string",
          "enum": [
            "arabic",
            "roman"
          ]
        },
        "border_style": {
          "type": "string",
          "enum": [
            "full",
            "full_grid",
            "top_bottom_only",
            "header_only",
            "none"
          ]
        },
        "note_label": {
          "type": "string"
        }
      }
    },
    "equations": {
      "type": "object",
      "required": [
        "numbering",
        "numbering_format"
      ],
      "additionalProperties": false,
      "properties": {
        "numbering": {
          "type": "string"
        },
        "numbering_format": {
          "type": "string"
        }
      }
    },
    "block_quotes": {
      "type": "object",
      "required": [
        "threshold_words",
        "left_indent",
        "no_quotation_marks"
      ],
      "additionalProperties": true,
      "properties": {
        "threshold_words": {
          "type": "number",
          "minimum": 1
        },
        "left_indent": {
          "type": "string"
        },
        "no_quotation_marks": {
          "type": "boolean"
        },
        "apa_ref": {
          "type": "string"
        }
      }
    },
    "appendices": {
      "type": "object",
      "required": [
        "label_format",
        "label_centered",
        "label_bold"
      ],
      "additionalProperties": true,
      "properties": {
        "label_format": {
          "type": "string"
        },
        "label_centered": {
          "type": "boolean"
        },
        "label_bold": {
          "type": "boolean"
        },
        "title_centered": {
          "type": "boolean"
        },
        "title_bold": {
          "type": "boolean"
        },
        "apa_ref": {
          "type": "string"
        }
      }
    },
    "footnotes": {
      "type": "object",
      "required": [
        "position",
        "font_size",
        "line_spacing"
      ],
      "additionalProperties": true,
      "properties": {
        "position": {
          "type": "string"
        },
        "font_size": {
          "type": "number"
        },
        "line_spacing": {
          "type": "number"
        },
        "apa_ref": {
          "type": "string"
        }
      }
    },
    "statistical_notation": {
      "type": "object",
      "required": [
        "italic_symbols"
      ],
      "additionalProperties": true,
      "properties": {
        "italic_symbols": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "apa_ref": {
          "type": "string"
        }
      }
    },
    "general_rules": {
      "type": "object",
      "required": [
        "doi_format",
        "url_format",
        "date_format",
        "et_al_threshold",
        "use_ampersand_in_citations",
        "use_ampersand_in_references",
        "oxford_comma"
      ],
      "additionalProperties": false,
      "properties": {
        "doi_format": {
          "type": "string"
        },
        "url_format": {
          "type": "string"
        },
        "date_format": {
          "type": "string"
        },
        "et_al_threshold": {
          "type": "number",
          "minimum": 1
        },
        "use_ampersand_in_citations": {
          "type": "boolean"
        },
        "use_ampersand_in_references": {
          "type": "boolean"
        },
        "oxford_comma": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "heading": {
      "type": "object",
      "required": [
        "bold",
        "italic",
        "centered",
        "font_size"
      ],
      "additionalProperties": true,
      "properties": {
        "bold": {
          "type": "boolean"
        },
        "italic": {
          "type": "boolean"
        },
        "centered": {
          "type": "boolean"
        },
        "underline": {
          "type": "boolean"
        },
        "font_size": {
          "type": "number"
        },
        "case": {
          "type": "string"
        },
        "numbering": {
          "type": "string"
        },
        "indent": {
          "type": "boolean"
        },
        "indent_size": {
          "type": "string"
        },
        "inline_with_text": {
          "type": "boolean"
        },
        "period_after_heading": {
          "type": "boolean"
        },
        "ends_with_period": {
          "type": "boolean"
        },
        "apa_ref": {
          "type": "string"
        }
      }
    }
  }
}
