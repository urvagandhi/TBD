{
  "style_name": "Springer LNCS",

  "document": {
    "font": "Times New Roman",
    "font_size": 10,
    "line_spacing": 1.0,
    "margins": {
      "top": "1in",
      "bottom": "1in",
      "left": "0.75in",
      "right": "0.75in"
    },
    "alignment": "justify",
    "columns": 1
  },

  "title_page": {
    "title_case": "Title Case",
    "title_bold": true,
    "title_centered": false,
    "title_font_size": 14
  },

  "abstract": {
    "label": "Abstract",
    "label_bold": true,
    "label_centered": false,
    "label_italic": false,
    "max_words": 250,
    "indent_first_line": false,
    "keywords_present": true,
    "keywords_label": "Keywords:",
    "keywords_italic": false
  },

  "headings": {
    "H1": {
      "bold": true,
      "italic": false,
      "centered": false,
      "underline": false,
      "case": "Title Case",
      "numbering": "numeric",
      "font_size": 12,
      "spacing_before": 12,
      "spacing_after": 6
    },

    "H2": {
      "bold": true,
      "italic": false,
      "centered": false,
      "underline": false,
      "case": "Title Case",
      "numbering": "numeric",
      "font_size": 11,
      "spacing_before": 10,
      "spacing_after": 4
    },

    "H3": {
      "bold": false,
      "italic": true,
      "centered": false,
      "underline": false,
      "indent": false,
      "case": "Sentence case",
      "numbering": "numeric",
      "inline_with_text": false,
      "font_size": 10,
      "spacing_before": 8,
      "spacing_after": 4
    }
  },

  "citations": {
    "style": "author-date",
    "brackets": "parentheses",
    "format_one_author": "(Author Year)",
    "format_two_authors": "(Author and Author Year)",
    "format_three_plus": "(Author et al. Year)",
    "format_numbered": "[N]",
    "include_page_for_quotes": false,
    "page_format": "p. 45"
  },

  "references": {
    "section_label": "References",
    "label_bold": true,
    "label_centered": false,
    "label_italic": false,
    "ordering": "alphabetical",
    "hanging_indent": true,
    "indent_size": "0.5in",
    "line_spacing": 1.0,
    "space_between_entries": false,
    "max_authors_before_et_al": 3,

    "formats": {
      "journal_article": "Author AA, Author BB (Year) Title of article. Journal Name Volume(Issue):Page–Page",
      "book": "Author AA (Year) Title of Book. Publisher, City",
      "book_chapter": "Author AA (Year) Title of chapter. In: Editor AA (ed) Title of Book. Publisher, City, pp Page–Page",
      "book_chapter_multiple_editors": "Author AA (Year) Title of chapter. In: Editor AA, Editor BB (eds) Title of Book. Publisher, City, pp Page–Page",
      "website": "Author AA (Year) Title of page. URL. Accessed Day Mon Year",
      "conference_paper": "Author AA (Year) Title of paper. In: Proceedings of Conference Name, pp Page–Page",
      "thesis": "Author AA (Year) Title of Thesis. University",
      "dataset": "Author AA (Year) Dataset Title. Repository. DOI"
    }
  },

  "figures": {
    "label_prefix": "Fig.",
    "label_bold": true,
    "label_italic": false,
    "caption_position": "below",
    "caption_italic": false,
    "caption_alignment": "left",
    "numbering": "arabic",
    "note_label": "Note:"
  },

  "tables": {
    "label_prefix": "Table",
    "label_bold": true,
    "label_italic": false,
    "caption_position": "above",
    "caption_italic": false,
    "caption_alignment": "left",
    "numbering": "arabic",
    "border_style": "top_bottom_only",
    "note_label": "Note:"
  },

  "equations": {
    "numbering": "right_aligned",
    "numbering_format": "(1)"
  },

  "block_quotes": {
    "threshold_words": 40,
    "left_indent": "0.5in",
    "no_quotation_marks": true,
    "citation_format": "(Author Year, p. X)"
  },

  "appendices": {
    "label_format": "Appendix {letter}",
    "label_centered": false,
    "label_bold": true,
    "title_centered": false,
    "title_bold": true,
    "numbering_style": "alphabetical"
  },

  "footnotes": {
    "position": "page_bottom",
    "font_size": 8,
    "line_spacing": 1.0,
    "numbering_style": "numeric"
  },

  "statistical_notation": {
    "italic_symbols": [
      "p",
      "n",
      "t",
      "F",
      "r",
      "R2"
    ],
    "confidence_interval_format": "CI 95%",
    "significance_levels": [
      "p < .05",
      "p < .01",
      "p < .001"
    ]
  },

  "general_rules": {
    "doi_format": "https://doi.org/xxxxx",
    "url_format": "direct url",
    "date_format": "YYYY",
    "et_al_threshold": 3,
    "use_ampersand_in_citations": false,
    "use_ampersand_in_references": false,
    "oxford_comma": false
  }
}