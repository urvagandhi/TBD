{
  "style_name": "APA 7th Edition",

  "document": {
    "font": "Times New Roman",
    "font_size": 12,
    "line_spacing": 2.0,
    "margins": {
      "top": "1in",
      "bottom": "1in",
      "left": "1in",
      "right": "1in"
    },
    "alignment": "left",
    "columns": 1
  },

  "title_page": {
    "title_case": "Title Case",
    "title_bold": true,
    "title_centered": true,
    "title_font_size": 12
  },

  "abstract": {
    "label": "Abstract",
    "label_bold": true,
    "label_centered": true,
    "label_italic": false,
    "max_words": 250,
    "indent_first_line": false,
    "keywords_present": true,
    "keywords_label": "Keywords:",
    "keywords_italic": true
  },

  "headings": {
    "H1": {
      "bold": true,
      "italic": false,
      "centered": true,
      "underline": false,
      "case": "Title Case",
      "numbering": "none",
      "font_size": 12
    },
    "H2": {
      "bold": true,
      "italic": false,
      "centered": false,
      "underline": false,
      "case": "Title Case",
      "numbering": "none",
      "font_size": 12
    },
    "H3": {
      "bold": true,
      "italic": true,
      "centered": false,
      "underline": false,
      "indent": true,
      "case": "Title Case",
      "numbering": "none",
      "inline_with_text": false,
      "font_size": 12
    }
  },

  "citations": {
    "style": "author-date",
    "brackets": "parentheses",
    "format_one_author": "(Smith, 2020)",
    "format_two_authors": "(Smith & Jones, 2020)",
    "format_three_plus": "(Smith et al., 2020)",
    "format_numbered": null,
    "include_page_for_quotes": true,
    "page_format": "p. 45"
  },

  "references": {
    "section_label": "References",
    "label_bold": true,
    "label_centered": true,
    "label_italic": false,
    "ordering": "alphabetical",
    "hanging_indent": true,
    "indent_size": "0.5in",
    "line_spacing": 2.0,
    "space_between_entries": false,
    "formats": {
      "journal_article": "Author, A. A., & Author, B. B. (Year). Title of article. Journal Name, Volume(Issue), Page\u2013Page. https://doi.org/xxxxx",
      "book": "Author, A. A. (Year). Title of work: Capital letter also for subtitle. Publisher.",
      "book_chapter": "Author, A. A., & Author, B. B. (Year). Title of chapter. In E. E. Editor (Ed.), Title of book (pp. page\u2013page). Publisher.",
      "website": "Author, A. A. (Year, Month Day). Title of page. Site Name. URL",
      "conference_paper": "Author, A. A. (Year, Month). Title of paper [Paper presentation]. Conference Name, Location."
    }
  },

  "figures": {
    "label_prefix": "Figure",
    "label_bold": true,
    "label_italic": false,
    "caption_position": "below",
    "caption_italic": true,
    "caption_alignment": "left",
    "numbering": "arabic",
    "note_label": "Note."
  },

  "tables": {
    "label_prefix": "Table",
    "label_bold": true,
    "label_italic": false,
    "caption_position": "above",
    "caption_italic": true,
    "caption_alignment": "left",
    "numbering": "arabic",
    "border_style": "top_bottom_only",
    "note_label": "Note."
  },

  "equations": {
    "numbering": "right_aligned",
    "numbering_format": "(1)"
  },

  "general_rules": {
    "doi_format": "https://doi.org/xxxxx",
    "url_format": "direct url",
    "date_format": "YYYY",
    "et_al_threshold": 3,
    "use_ampersand_in_citations": true,
    "use_ampersand_in_references": true,
    "oxford_comma": true
  }
}
