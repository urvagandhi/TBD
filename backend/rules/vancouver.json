{
  "style_name": "Vancouver",
  "document": {
    "font": "Times New Roman",
    "font_size": 12,
    "line_spacing": 2.0,
    "margins": {
      "top": "1in",
      "bottom": "1in",
      "left": "1in",
      "right": "1in"
    },
    "alignment": "left",
    "columns": 1
  },
  "title_page": {
    "title_case": "Title Case",
    "title_bold": false,
    "title_centered": false,
    "title_font_size": 12
  },
  "abstract": {
    "label": "Abstract",
    "label_bold": true,
    "label_centered": false,
    "label_italic": false,
    "max_words": 250,
    "indent_first_line": false,
    "keywords_present": true,
    "keywords_label": "Keywords:",
    "keywords_italic": false
  },
  "headings": {
    "H1": {
      "bold": true,
      "italic": false,
      "centered": false,
      "underline": false,
      "case": "UPPERCASE",
      "numbering": "none",
      "font_size": 12
    },
    "H2": {
      "bold": true,
      "italic": false,
      "centered": false,
      "underline": false,
      "case": "Title Case",
      "numbering": "none",
      "font_size": 12
    },
    "H3": {
      "bold": false,
      "italic": true,
      "centered": false,
      "underline": false,
      "indent": false,
      "case": "Sentence case",
      "numbering": "none",
      "inline_with_text": false,
      "font_size": 12
    }
  },
  "citations": {
    "style": "numbered",
    "brackets": "square",
    "format_one_author": "[N]",
    "format_two_authors": "[N]",
    "format_three_plus": "[N]",
    "format_numbered": "[N]",
    "include_page_for_quotes": false,
    "page_format": "p. 45"
  },
  "references": {
    "section_label": "References",
    "label_bold": true,
    "label_centered": false,
    "label_italic": false,
    "ordering": "appearance",
    "hanging_indent": true,
    "indent_size": "0.5in",
    "line_spacing": 1.0,
    "space_between_entries": false,
    "formats": {
      "journal_article": "Author AA, Author BB. Title of article. Journal Abbreviation. Year;Volume(Issue):Page-Page. doi:10.xxxx/xxxxx.",
      "book": "Author AA. Title of Book. Edition. Place: Publisher; Year.",
      "book_chapter": "Author AA. Title of chapter. In: Editor AA, editor. Title of Book. Place: Publisher; Year. p. Page-Page.",
      "website": "Author AA. Title of page [Internet]. Place: Publisher; Year [cited Year Mon Day]. Available from: URL",
      "conference_paper": "Author AA. Title of paper. In: Conference Name; Year Mon Day; City. Place: Publisher; Year. p. Page-Page."
    }
  },
  "figures": {
    "label_prefix": "Figure",
    "label_bold": false,
    "label_italic": false,
    "caption_position": "below",
    "caption_italic": false,
    "caption_alignment": "left",
    "numbering": "arabic",
    "note_label": "Note:"
  },
  "tables": {
    "label_prefix": "Table",
    "label_bold": false,
    "label_italic": false,
    "caption_position": "above",
    "caption_italic": false,
    "caption_alignment": "left",
    "numbering": "arabic",
    "border_style": "header_only",
    "note_label": "Note:"
  },
  "equations": {
    "numbering": "right_aligned",
    "numbering_format": "(1)"
  },
  "general_rules": {
    "doi_format": "doi:10.xxxx/xxxxx",
    "url_format": "Available from: URL",
    "date_format": "Year Mon Day",
    "et_al_threshold": 6,
    "use_ampersand_in_citations": false,
    "use_ampersand_in_references": false,
    "oxford_comma": false
  }
}